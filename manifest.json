{
  "name": "SARG",
  "short_name": "SARG",
  "start_url": "/?open=whiteboard",
  "display": "standalone",
  "background_color": "#121212",
  "theme_color": "#F06292",
  "description": "Sistema Avanzado de Respuestas Generativas",
  "icons": [
    {
      "src": "/robot.png",
      "sizes": "192x192",
      "type": "image/png"
    },
    {
      "src": "/robot.png",
      "sizes": "512x512",
      "type": "image/png"
    }
  ],
  "file_handlers": [
    {
      "action": "/?open=whiteboard",
      "accept": {
        "application/pdf": [".pdf"]
      }
    }
  ],
  "share_target": {
    "action": "/_share-target",
    "method": "POST",
    "enctype": "multipart/form-data",
    "params": {
      "title": "name",
      "text": "description",
      "url": "link",
      "files": [
        {
          "name": "pdfFile",
          "accept": ["application/pdf", ".pdf"]
        }
      ]
    }
  }
}
